# ============================================================
# Flux AI — E2E Test Configuration (Playwright)
# ============================================================
#
# How to use:
#   1. cp .env.e2e.example .env.e2e
#   2. fill E2E_ENDPOINT / E2E_API_KEY / E2E_NAME in .env.e2e
#   3. pnpm e2e
#
# CI: inject the same vars via GitLab CI/CD masked variables.
# ============================================================

# OpenAI-compatible proxy URL (e.g. https://your-proxy.example.com/v1)
E2E_ENDPOINT=https://your-proxy.example.com/v1

# API key for the proxy above
E2E_API_KEY=sk-REPLACE_ME

# Display name used in the login form
E2E_NAME=Ada Lovelace

# Model id to use for streaming assertions (pick a fast, non-quota-bound one)
E2E_MODEL=speed

# Base URL the dev server listens on (default: http://localhost:3008)
E2E_BASE_URL=http://localhost:3008
